---
import Layout from '../../layouts/Layout.astro';
import PlanesServicio from '../../components/PlanesServicio.astro';
// Tablas "Otros servicios de video" del Catálogo MK Media Digital 2026.
const otrosVideo = [
  {
    titulo: 'Suscripción video 30 segundos',
    encabezado: 'Servicio',
    filas: [
      ['Video Básico (4 videos, 1 por semana)', 'Un video semanal'],
      ['Video Inter (4 videos, 1 por semana)', 'Un video semanal'],
      ['Video Completo (4 videos, 1 por semana)', 'Un video semanal'],
    ],
  },
  {
    titulo: 'Paquete creador de contenidos',
    encabezado: 'Servicio',
    filas: [
      ['Video Básico', '2-5 días hábiles'],
      ['Video Inter', '3-7 días hábiles'],
      ['Video Completo', '5-10 días hábiles'],
      ['Creación de imagen', '3-7 días hábiles'],
      ['TikTok', '3-7 días hábiles'],
      ['Reels', '3-7 días hábiles'],
    ],
  },
  {
    titulo: 'Animación de logotipo',
    encabezado: 'Estilo',
    filas: [
      ['Básico', '2-3 días hábiles'],
      ['Inter', '2-3 días hábiles'],
      ['Completo', '2-3 días hábiles'],
    ],
  },
  {
    titulo: 'Cambios de medida en videos',
    encabezado: 'Servicio',
    filas: [
      ['Video Básico', '2-3 días hábiles'],
      ['Video Inter', '2-3 días hábiles'],
      ['Video Completo', '2-3 días hábiles'],
    ],
  },
];
---
<Layout title="Video Marketing | MK Media Digital">
<!-- Hero Section -->
<section class="relative pt-32 pb-20 md:pt-48 md:pb-32 bg-primary-container overflow-hidden">
<div class="max-w-container-max mx-auto px-gutter relative z-10 text-center">
<h1 class="font-display-hero-mobile md:font-display-hero text-display-hero-mobile md:text-display-hero text-on-primary mb-6">
                VIDEOMARKETING ESTRATÉGICO
            </h1>
<p class="max-w-3xl mx-auto font-body-lg text-body-lg text-on-primary-container/90 mb-12">
                Captura la atención de tu audiencia y multiplica tus conversiones con contenido audiovisual diseñado para destacar y vender en cualquier plataforma.
            </p>
<div class="relative w-full max-w-4xl mx-auto mt-12 transform hover:scale-[1.02] transition-transform duration-700">
<img alt="Ilustración 3D de video marketing: reproductor con botón de play, claqueta y línea de tiempo de edición" class="w-full rounded-2xl shadow-2xl border border-on-primary-container/20" src="/img/servicios/videomarketing.jpg" width="1600" height="900" fetchpriority="high"/>
</div>
</div>
<!-- Background accents -->
<div class="absolute top-0 left-0 w-full h-full pointer-events-none opacity-20">
<div class="absolute top-20 left-10 w-64 h-64 bg-primary-fixed rounded-full blur-[100px]"></div>
<div class="absolute bottom-10 right-10 w-96 h-96 bg-on-primary-container rounded-full blur-[120px]"></div>
</div>
</section>
<!-- Benefits Bar -->
<section class="bg-surface-container-lowest py-16">
<div class="max-w-container-max mx-auto px-gutter">
<div class="grid grid-cols-1 md:grid-cols-3 gap-12">
<div class="flex items-center gap-6 p-4">
<div class="w-16 h-16 rounded-full bg-primary-fixed flex items-center justify-center text-primary">
<span class="material-symbols-outlined text-3xl" data-icon="favorite">favorite</span>
</div>
<div>
<h4 class="font-headline-md text-headline-md text-on-surface">Mayor Retención</h4>
<p class="font-body-md text-body-md text-on-surface-variant">Conectamos emocionalmente.</p>
</div>
</div>
<div class="flex items-center gap-6 p-4">
<div class="w-16 h-16 rounded-full bg-primary-fixed flex items-center justify-center text-primary">
<span class="material-symbols-outlined text-3xl" data-icon="trending_up">trending_up</span>
</div>
<div>
<h4 class="font-headline-md text-headline-md text-on-surface">Alcance Viral</h4>
<p class="font-body-md text-body-md text-on-surface-variant">Contenido diseñado para compartir.</p>
</div>
</div>
<div class="flex items-center gap-6 p-4">
<div class="w-16 h-16 rounded-full bg-primary-fixed flex items-center justify-center text-primary">
<span class="material-symbols-outlined text-3xl" data-icon="devices">devices</span>
</div>
<div>
<h4 class="font-headline-md text-headline-md text-on-surface">Multiplataforma</h4>
<p class="font-body-md text-body-md text-on-surface-variant">Adaptable a todo formato.</p>
</div>
</div>
</div>
</div>
</section>
<!-- Plans Section -->
<PlanesServicio service="videomarketing" heading="Elige el tipo de video que necesitas" featured="video-inter" />
<!-- Special Service (Voiceover) -->
<section class="bg-surface-container-lowest py-section-padding-desktop">
<div class="max-w-container-max mx-auto px-gutter">
<div class="bg-surface-container-low rounded-xl overflow-hidden grid grid-cols-1 md:grid-cols-2">
<div class="p-12 md:p-20 flex flex-col justify-center">
<h3 class="font-headline-lg text-headline-lg mb-4">Narración de voz en off</h3>
<p class="font-label-sm text-label-sm text-primary uppercase tracking-widest mb-6">60 seg · 30 seg · Menos de 30 seg</p>
<p class="font-body-lg text-body-lg text-on-surface-variant mb-10">
                        Te ayudamos a crear el guion y a elegir la voz adecuada para darle vida a tu proyecto. La narración de voz no está incluida en el servicio de Video Marketing: se contrata por separado.
                    </p>
<div>
<a href="/producto?service=videomarketing&plan=narracion-voz" class="bg-primary-container text-on-primary px-10 py-4 rounded-lg font-bold hover:scale-105 transition-standard btn-magnetic press-effect text-center inline-block"><span class="icon-wrap">COTIZAR</span></a>
</div>
</div>
<div class="relative min-h-[400px]">
<img alt="Professional Studio Mic Setup" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBPKu42EU8B_dEIfFjWWQUnk_cu_9F_9uf9zrJXF5trnZ7z9iFlWYnV-trQeUe5SVlG5fVQ6hsCzIPWpzp9TV6FP_35sI9gDGvfzVl0UlPNkwl1HC_kBA3wnnmPhzGDLztMHr34wgyHk2ummY7i24dkRCr3IjkM_amuO0tHNNbQ8LouuEvMEeqJd6YfcSLk9jVbt3rB5wJccUcT-Jp9gvsaAhn8NQpk1It8V8OQMKkRWKY6FEgnbWhMlmbvB22TJYst_w7pUZhEnMMg"/>
</div>
</div>
</div>
</section>
<!-- Tables Section -->
<!-- Otros servicios de video (Catálogo MK Media Digital 2026) -->
<section class="bg-surface-container-lowest py-section-padding-desktop">
<div class="max-w-container-max mx-auto px-gutter">
<div class="mb-12 reveal">
<h2 class="font-headline-lg text-headline-lg text-on-surface mb-2">Otros servicios de video</h2>
<p class="font-body-lg text-body-lg text-on-surface-variant">Complementa con otras opciones y sus tiempos de entrega.</p>
</div>
<div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
{otrosVideo.map(tabla => (
<div class="bg-white rounded-xl border border-outline-variant/30 overflow-x-auto">
<div class="bg-primary-fixed-dim p-4">
<h4 class="font-bold text-on-primary-fixed">{tabla.titulo}</h4>
</div>
<table class="w-full text-left font-body-md">
<tbody>
<tr class="border-b border-outline-variant/20"><th class="p-4 bg-surface-container">{tabla.encabezado}</th><th class="p-4 bg-surface-container text-right">Tiempos de entrega</th></tr>
{tabla.filas.map(f => (
<tr class="border-b border-outline-variant/20"><td class="p-4 text-on-surface">{f[0]}</td><td class="p-4 text-on-surface-variant text-right whitespace-nowrap">{f[1]}</td></tr>
))}
</tbody>
</table>
</div>
))}
</div>
<p class="text-center text-on-surface-variant font-body-md text-body-md mt-12">
En caso de requerir otro tipo de material audiovisual debe ser cotizado en costo y en tiempos de entrega, ya que depende del tipo de proyecto y complejidad.
</p>
</div>
</section>
</Layout>
