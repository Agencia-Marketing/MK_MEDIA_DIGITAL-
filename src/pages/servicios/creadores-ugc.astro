---
import Layout from '../../layouts/Layout.astro';
import PlanesServicio from '../../components/PlanesServicio.astro';
---
<Layout title="Creadores UGC | MK Media Digital">
<!-- Hero Section -->
<section class="relative pt-32 pb-20 md:pt-48 md:pb-32 bg-primary-container overflow-hidden">
<div class="max-w-container-max mx-auto px-gutter relative z-10 text-center">
<h1 class="font-display-hero-mobile md:font-display-hero text-display-hero-mobile md:text-display-hero text-on-primary mb-6">
                CREADORES UGC
            </h1>
<p class="max-w-3xl mx-auto font-body-lg text-body-lg text-on-primary-container/90 mb-12">
                Humaniza tu marca e impulsa tus ventas con contenido auténtico creado por usuarios reales. El "boca a boca" adaptado a la era digital.
            </p>
<div class="relative w-full max-w-4xl mx-auto mt-12 transform hover:scale-[1.02] transition-transform duration-700">
<img alt="UGC Concept Illustration" class="w-full rounded-2xl shadow-2xl border border-on-primary-container/20" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBXRqlRBnXPOUpmhBcGowWVCIMgnbmqS7eJ6MzFyQAuiIYe8AOYDMStUoukmUWCN8MRIfaIi1YOYZdd2_LhaAMOj5UqRR4dKJO86QYWJXRSTe1NV6wOZbSRPE9tnSqH6ykR0pqLMTT11U84pt_v_Bg5HQ1mMP0_2cWDTt6BftIERQpvTFtlzXT7o8gWOtQ0tXnDN-QGOEpC1sm80OeaMfYxW0Tu4blx94ljKHKIouQLTRxQ17RjDopYeYc1rKAHXocX_x9mJdUFhIeU"/>
</div>
</div>
<!-- Background accents -->
<div class="absolute top-0 left-0 w-full h-full pointer-events-none opacity-20">
<div class="absolute top-20 left-10 w-64 h-64 bg-primary-fixed rounded-full blur-[100px]"></div>
<div class="absolute bottom-10 right-10 w-96 h-96 bg-on-primary-container rounded-full blur-[120px]"></div>
</div>
</section>
<!-- Feature & Pricing Section -->
<PlanesServicio service="creadores-ugc" heading="Creadores UGC" />
<!-- Simple Portfolio Section Placeholder -->
<section class="py-section-padding-mobile md:py-section-padding-desktop px-gutter max-w-container-max mx-auto">
<div class="text-center mb-16">
<span class="text-primary font-label-sm uppercase tracking-widest">Portafolio</span>
<h2 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg mt-4">Nuestras Historias de Éxito</h2>
</div>
<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
<div class="aspect-[9/16] bg-surface-container rounded-2xl overflow-hidden border border-outline-variant group">
<div class="w-full h-full bg-cover bg-center" data-alt="Vertical mobile video frame showing a young woman unboxing a premium skincare set with a delighted expression. The scene is bright and airy with high-end minimalist decor in the background. The lighting is flattering and highlights the product textures clearly. Purple atmospheric accents tie back to the brand identity." style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDboCNNlPWryZ8dsbTiECWgkBWHImZk9tG1Cax08w_IXqJPOPic5Zl3zHizfjaPMltgLV2ELYlg5ZyzgRVohg_uQ1djFTkqnamRncsuLdpjwGVE8uuqdFGWbdGsJWP9HkUm0KBW3F33ohp-iWePSYzHyNlzS2eW5lKz546OVP9NjwtSY_uj3WceI_WmI_Pb0rZVfmiNLKAqpDPuO6At_x92z5wnpyMHtw_zpGV2plOBthD98sjOsJbWGvmgu-QV-myHYtpfU2CUhcWG')">
<div class="w-full h-full bg-black/20 group-hover:bg-black/40 transition-all flex items-center justify-center">
<span class="material-symbols-outlined text-white text-6xl opacity-0 group-hover:opacity-100 transform scale-50 group-hover:scale-100 transition-all" data-icon="play_circle">play_circle</span>
</div>
</div>
</div>
<div class="aspect-[9/16] bg-surface-container rounded-2xl overflow-hidden border border-outline-variant group">
<div class="w-full h-full bg-cover bg-center" data-alt="A group of diverse friends laughing and looking at a smartphone together in a modern city loft. The vibe is genuine, candid, and full of energy. The overall aesthetic is clean and high-contrast, fitting a modern digital agency style with warm ambient lighting." style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuCiIhPHIZBKTe0uvdORmL_uq_PQwTRd82VEzNYCaDWA6Q_9AxBvEu-Us_iSjkhp6DuelcfbN97lzCKb6tbeXQDX82XQexvUyoOt4wTRF27HPm38P2RxODOT_IiwiLONephr8Vr1kvf7Jsv07kzcL7Dj6zF1m4NwYpxYfyCpEQX4DfsFz_GB5Ou19ItY3oFyi0IWgShR9HAPljrGZbj-wcjNpzwOddc_Rm0CcJN6aHpBvMETQjX7A2I4c_KMNXFi8FhDkIWwRAw8wqKI')">
<div class="w-full h-full bg-black/20 group-hover:bg-black/40 transition-all flex items-center justify-center">
<span class="material-symbols-outlined text-white text-6xl opacity-0 group-hover:opacity-100 transform scale-50 group-hover:scale-100 transition-all" data-icon="play_circle">play_circle</span>
</div>
</div>
</div>
<div class="aspect-[9/16] bg-surface-container rounded-2xl overflow-hidden border border-outline-variant group">
<div class="w-full h-full bg-cover bg-center" data-alt="Close up of a creator speaking passionately into a high-quality desktop microphone while gestures with their hands. Authentic domestic setting with soft depth of field. High-end digital creator aesthetic with crisp focus and professional color grading featuring deep purples and clean whites." style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuD8qSJsGNPoruK-E2kLSOU-y5ltd-OSSuZzvaiYXv68ZC6z4qkjKa8n8AZh8sG8JkFsLG0t5vNjjrYfJV5FcOh8VBrioinH5NT6vwI6mqY0WbFYkvRaClB67rJV9BRxK-wvEzepuAwtP-A85LQC0sCOfQFDEWfwKIdoRR4v7G9R8cZt6O9K4WU0e_Cw42gutiTDfN8geD7JoUxoqKmAcW7aN5Q7HGEJi1jUqXtpU31INLZz_MmvxiQAaN6ny6AMFoeruYLSSJ5vTrSg')">
<div class="w-full h-full bg-black/20 group-hover:bg-black/40 transition-all flex items-center justify-center">
<span class="material-symbols-outlined text-white text-6xl opacity-0 group-hover:opacity-100 transform scale-50 group-hover:scale-100 transition-all" data-icon="play_circle">play_circle</span>
</div>
</div>
</div>
</div>
</section>
</Layout>
