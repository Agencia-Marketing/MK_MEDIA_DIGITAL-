---
import Layout from '../../layouts/Layout.astro';
import PlanesServicio from '../../components/PlanesServicio.astro';
---
<Layout title="Embudos de ventas con filtro API de Facebook | MK Media Digital">
<main>
<!-- Hero Section -->
<section class="relative pt-32 pb-20 md:pt-48 md:pb-32 bg-primary-container overflow-hidden">
<div class="max-w-container-max mx-auto px-gutter relative z-10 text-center">
<h1 class="font-display-hero-mobile md:font-display-hero text-display-hero-mobile md:text-display-hero text-on-primary mb-6">
                CONFIGURACIÓN DE EMBUDOS DE VENTA
            </h1>
<p class="max-w-3xl mx-auto font-body-lg text-body-lg text-on-primary-container/90 mb-12">
                Transforma el tráfico de tus redes sociales en un flujo constante de clientes potenciales cualificados, operando en piloto automático 24/7.
            </p>
<div class="relative w-full max-w-4xl mx-auto mt-12 transform hover:scale-[1.02] transition-transform duration-700">
<img alt="Ilustración detallada de un embudo de ventas digital profesional con elementos 3D transparentes y logotipos de redes sociales integrados en un flujo de automatización moderno." class="w-full rounded-2xl shadow-2xl border border-on-primary-container/20" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBUu9IlokmAkV3pjZ1CQete1g3cwm7HTZZMUR63uS7Icu0PC9ycgjyJm66sXVkbaO2p5gHN9vgE_647EQ8uqvdAIC9Zu2Q_xhXgNSNT2EJexJF1FZaCxnbaz0zvvb0vTedgRzTjcsZpmLVHHPjq6IQcfh5UeFPefacm08RZL5U4wjDJ41VtgwnWAwNy7P1nF3ejeLe1lN6lyCq-1cSVjVxECEvuLtnTbxJO-7Yy8qUOOMmSY_qCdEXAT-Lq4BebnNqHcsuYC5odq53g"/>
</div>
</div>
<!-- Background accents -->
<div class="absolute top-0 left-0 w-full h-full pointer-events-none opacity-20">
<div class="absolute top-20 left-10 w-64 h-64 bg-primary-fixed rounded-full blur-[100px]"></div>
<div class="absolute bottom-10 right-10 w-96 h-96 bg-on-primary-container rounded-full blur-[120px]"></div>
</div>
</section>
<!-- Pricing / Features Section -->
<PlanesServicio service="embudos-venta" heading="Embudos de ventas con filtro API de Facebook" />
</main>
</Layout>
