---
import Layout from "../../layouts/Layout.astro";
import PlanesServicio from "../../components/PlanesServicio.astro";
---

<Layout title="Administración de redes sociales | MK Media Digital">
  <!-- Hero Section -->
  <section
    class="relative pt-32 pb-20 md:pt-48 md:pb-32 bg-primary-container overflow-hidden"
  >
    <div
      class="max-w-container-max mx-auto px-gutter relative z-10 text-center"
    >
      <h1
        class="font-display-hero-mobile md:font-display-hero text-display-hero-mobile md:text-display-hero text-on-primary mb-6"
      >
        Domina tus Redes Sociales.
      </h1>
      <p
        class="max-w-3xl mx-auto font-body-lg text-body-lg text-on-primary-container/90 mb-12"
      >
        Convierte a tus seguidores en clientes leales con estrategias de
        contenido que atrapan, retienen y multiplican tus ventas.
      </p>
      <div
        class="relative w-full max-w-4xl mx-auto mt-12 transform hover:scale-[1.02] transition-transform duration-700"
      >
        <img
          alt="Ilustración 3D de gestión de redes sociales: teléfono con feed de contenido rodeado de iconos de interacción"
          class="w-full rounded-2xl shadow-2xl border border-on-primary-container/20"
          src="/img/servicios/redes-sociales.jpg" width="1600" height="900" fetchpriority="high"/>
      </div>
    </div>
    <!-- Background accents -->
    <div
      class="absolute top-0 left-0 w-full h-full pointer-events-none opacity-20"
    >
      <div
        class="absolute top-20 left-10 w-64 h-64 bg-primary-fixed rounded-full blur-[100px]"
      >
      </div>
      <div
        class="absolute bottom-10 right-10 w-96 h-96 bg-on-primary-container rounded-full blur-[120px]"
      >
      </div>
    </div>
  </section>
  <!-- Benefits Bar -->
  <section
    class="bg-surface-container-lowest py-20 relative z-20 -mt-12 md:-mt-24"
  >
    <div class="max-w-container-max mx-auto px-gutter">
      <div
        class="grid grid-cols-1 md:grid-cols-3 gap-12 bg-white p-12 rounded-xl shadow-xl border border-outline-variant/30"
      >
        <!-- Benefit 1 -->
        <div class="flex flex-col items-center text-center">
          <div
            class="w-16 h-16 bg-primary-fixed rounded-full flex items-center justify-center mb-6 text-primary"
          >
            <span class="material-symbols-outlined text-4xl">target</span>
          </div>
          <h3 class="font-headline-md text-headline-md mb-4 text-primary">
            Estrategia Definida
          </h3>
          <p class="font-body-md text-body-md text-on-surface-variant">
            Trazamos la ruta exacta basada en datos para conectar tu marca con
            la audiencia ideal.
          </p>
        </div>
        <!-- Benefit 2 -->
        <div class="flex flex-col items-center text-center">
          <div
            class="w-16 h-16 bg-primary-fixed rounded-full flex items-center justify-center mb-6 text-primary"
          >
            <span class="material-symbols-outlined text-4xl">trending_up</span>
          </div>
          <h3 class="font-headline-md text-headline-md mb-4 text-primary">
            Crecimiento Escalable
          </h3>
          <p class="font-body-md text-body-md text-on-surface-variant">
            Impulsamos tu comunidad con métricas reales usando GA4, optimización
            de conversiones y resultados tangibles.
          </p>
        </div>
        <!-- Benefit 3 -->
        <div class="flex flex-col items-center text-center">
          <div
            class="w-16 h-16 bg-primary-fixed rounded-full flex items-center justify-center mb-6 text-primary"
          >
            <span class="material-symbols-outlined text-4xl">lightbulb</span>
          </div>
          <h3 class="font-headline-md text-headline-md mb-4 text-primary">
            Contenido Innovador
          </h3>
          <p class="font-body-md text-body-md text-on-surface-variant">
            Destaca en el feed con formatos creativos y visuales atractivos que
            rompen el molde del mercado.
          </p>
        </div>
      </div>
    </div>
  </section>
  <!-- Ecosistema 360 Section -->
  <section
    class="bg-surface-container-low py-section-padding-mobile md:py-section-padding-desktop"
  >
    <div class="max-w-container-max mx-auto px-gutter text-center">
      <h2
        class="font-headline-lg-mobile md:font-headline-lg text-headline-lg-mobile md:text-headline-lg mb-4 text-on-surface"
      >
        Ecosistema Digital 360
      </h2>
      <p
        class="font-body-lg text-body-lg text-on-secondary-fixed-variant mb-16"
      >
        Dominamos las plataformas clave para tu negocio.
      </p>
      <div class="flex flex-col gap-12">
        <!-- Row 1 -->
        <div class="flex flex-wrap justify-center gap-8 md:gap-16">
          <div class="flex flex-col items-center gap-4">
            <div
              class="w-20 h-20 bg-white rounded-full shadow-lg flex items-center justify-center text-primary hover:scale-110 transition-transform"
            >
              <svg class="w-9 h-9 fill-current" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M24 12.07C24 5.44 18.63.07 12 .07S0 5.44 0 12.07c0 5.99 4.39 10.95 10.13 11.85v-8.38H7.08v-3.47h3.05V9.43c0-3.01 1.79-4.67 4.53-4.67 1.31 0 2.69.24 2.69.24v2.95h-1.51c-1.49 0-1.96.93-1.96 1.87v2.25h3.33l-.53 3.47h-2.8v8.38C19.61 23.02 24 18.06 24 12.07z"/></svg>
            </div>
            <span
              class="font-label-sm text-label-sm text-secondary uppercase tracking-widest"
              >Facebook</span
            >
          </div>
          <div class="flex flex-col items-center gap-4">
            <div
              class="w-20 h-20 bg-white rounded-full shadow-lg flex items-center justify-center text-primary hover:scale-110 transition-transform"
            >
              <svg class="w-9 h-9 fill-current" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41-.56-.22-.96-.48-1.38-.9-.42-.42-.68-.82-.9-1.38-.16-.42-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16zM12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.9.33 4.14.63c-.79.31-1.46.72-2.13 1.38C1.35 2.68.94 3.35.63 4.14.33 4.9.13 5.78.07 7.05.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.27.26 2.15.56 2.91.31.79.72 1.46 1.38 2.13.67.67 1.34 1.08 2.13 1.38.76.3 1.64.5 2.91.56C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c1.27-.06 2.15-.26 2.91-.56.79-.3 1.46-.72 2.13-1.38.67-.67 1.08-1.34 1.38-2.13.3-.76.5-1.64.56-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.27-.26-2.15-.56-2.91-.3-.79-.72-1.46-1.38-2.13C21.32 1.35 20.65.94 19.86.63c-.76-.3-1.64-.5-2.91-.56C15.67.01 15.26 0 12 0zm0 5.84a6.16 6.16 0 100 12.32 6.16 6.16 0 000-12.32zM12 16a4 4 0 110-8 4 4 0 010 8zm7.85-10.41a1.44 1.44 0 11-2.88 0 1.44 1.44 0 012.88 0z"/></svg>
            </div>
            <span
              class="font-label-sm text-label-sm text-secondary uppercase tracking-widest"
              >Instagram</span
            >
          </div>
          <div class="flex flex-col items-center gap-4">
            <div
              class="w-20 h-20 bg-white rounded-full shadow-lg flex items-center justify-center text-primary hover:scale-110 transition-transform"
            >
              <svg class="w-9 h-9 fill-current" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </div>
            <span
              class="font-label-sm text-label-sm text-secondary uppercase tracking-widest"
              >X</span
            >
          </div>
        </div>
        <!-- Row 2 -->
        <div class="flex flex-wrap justify-center gap-8 md:gap-16">
          <div class="flex flex-col items-center gap-4">
            <div
              class="w-20 h-20 bg-white rounded-full shadow-lg flex items-center justify-center text-primary hover:scale-110 transition-transform"
            >
              <svg class="w-9 h-9 fill-current" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </div>
            <span
              class="font-label-sm text-label-sm text-secondary uppercase tracking-widest"
              >LinkedIn</span
            >
          </div>
          <div class="flex flex-col items-center gap-4">
            <div
              class="w-20 h-20 bg-white rounded-full shadow-lg flex items-center justify-center text-primary hover:scale-110 transition-transform"
            >
              <svg class="w-9 h-9 fill-current" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.436-2.878-2.436-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.271 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.39 18.62.026 12.017.026"/></svg>
            </div>
            <span
              class="font-label-sm text-label-sm text-secondary uppercase tracking-widest"
              >Pinterest</span
            >
          </div>
          <div class="flex flex-col items-center gap-4">
            <div
              class="w-20 h-20 bg-white rounded-full shadow-lg flex items-center justify-center text-primary hover:scale-110 transition-transform"
            >
              <svg class="w-9 h-9 fill-current" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z"/></svg>
            </div>
            <span
              class="font-label-sm text-label-sm text-secondary uppercase tracking-widest"
              >Google Business</span
            >
          </div>
          <div class="flex flex-col items-center gap-4">
            <div
              class="w-20 h-20 bg-white rounded-full shadow-lg flex items-center justify-center text-primary hover:scale-110 transition-transform"
            >
              <svg class="w-9 h-9 fill-current" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
            </div>
            <span
              class="font-label-sm text-label-sm text-secondary uppercase tracking-widest"
              >TikTok</span
            >
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- Pricing Plans Section -->
  <PlanesServicio
    service="redes-sociales"
    heading="Elige tus redes sociales"
    featured="plan-integral"
  />
  <!-- Portfolio Section -->
  <section
    class="bg-surface-container-lowest py-section-padding-mobile md:py-section-padding-desktop border-t border-outline-variant/20"
  >
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="mb-16">
        <h2
          class="font-headline-lg-mobile md:font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface mb-2"
        >
          Nuestro Trabajo
        </h2>
        <p class="font-body-lg text-body-lg text-on-surface-variant">
          Casos de éxito y marcas que confían en nosotros.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- ACSI -->
        <div
          class="group relative aspect-square rounded-xl overflow-hidden cursor-pointer"
        >
          <img
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
            src="/img/portfolio/redes-sociales/acsi-lineas.png"
            alt="Publicación de redes sociales - ACSI"
            loading="lazy"
          />
        </div>
        <!-- Martiniano -->
        <div
          class="group relative aspect-square rounded-xl overflow-hidden cursor-pointer"
        >
          <img
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
            src="/img/portfolio/redes-sociales/martiniano-post.png"
            alt="Publicación de redes sociales - Martiniano"
            loading="lazy"
          />
        </div>
        <!-- AV Films -->
        <div
          class="group relative aspect-square rounded-xl overflow-hidden cursor-pointer"
        >
          <img
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
            src="/img/portfolio/redes-sociales/av-films.jpg"
            alt="Publicación de redes sociales - AV Films"
            loading="lazy"
          />
        </div>
        <!-- Carpiizone -->
        <div
          class="group relative aspect-square rounded-xl overflow-hidden cursor-pointer"
        >
          <img
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
            src="/img/portfolio/redes-sociales/carpiizone.jpg"
            alt="Publicación de redes sociales - Carpiizone"
            loading="lazy"
          />
        </div>
        <!-- Ellie Flowers -->
        <div
          class="group relative aspect-square rounded-xl overflow-hidden cursor-pointer"
        >
          <img
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
            src="/img/portfolio/redes-sociales/ellie-flowers.jpg"
            alt="Publicación de redes sociales - Ellie Flowers"
            loading="lazy"
          />
        </div>
        <!-- Mavel Spa -->
        <div
          class="group relative aspect-square rounded-xl overflow-hidden cursor-pointer"
        >
          <img
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
            src="/img/portfolio/redes-sociales/mavel-spa.jpg"
            alt="Publicación de redes sociales - Mavel Spa"
            loading="lazy"
          />
        </div>
        <!-- Post -->
        <div
          class="group relative aspect-square rounded-xl overflow-hidden cursor-pointer"
        >
          <img
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
            src="/img/portfolio/redes-sociales/post-cuadrado.jpg"
            alt="Publicación de redes sociales"
            loading="lazy"
          />
        </div>
        <!-- Post -->
        <div
          class="group relative aspect-square rounded-xl overflow-hidden cursor-pointer"
        >
          <img
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
            src="/img/portfolio/redes-sociales/post-01.jpg"
            alt="Publicación de redes sociales"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>
</Layout>
