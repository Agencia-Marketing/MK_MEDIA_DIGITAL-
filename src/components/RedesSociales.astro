---
/* Enlaces a redes sociales. Las URLs viven en content/settings/site.json;
   los logotipos van como SVG en línea porque Material Symbols no incluye
   marcas de terceros. */
import site from '../content/settings/site.json';

export interface Props {
  /** 'footer' → círculo translúcido sobre fondo oscuro.
   *  'outline' → círculo con borde sobre fondo claro. */
  variant?: 'footer' | 'outline';
}

const { variant = 'footer' } = Astro.props;
const { social, brand } = site;

const ICONOS: Record<string, string> = {
