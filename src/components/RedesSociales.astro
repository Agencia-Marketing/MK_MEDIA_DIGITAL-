  Facebook: 'M24 12.07C24 5.44 18.63.07 12 .07S0 5.44 0 12.07c0 5.99 4.39 10.95 10.13 11.85v-8.38H7.08v-3.47h3.05V9.43c0-3.01 1.79-4.67 4.53-4.67 1.31 0 2.69.24 2.69.24v2.95h-1.51c-1.49 0-1.96.93-1.96 1.87v2.25h3.33l-.53 3.47h-2.8v8.38C19.61 23.02 24 18.06 24 12.07z',
};

const ESTILOS = {
  footer: 'social-link w-10 h-10 rounded-full flex items-center justify-center transition-colors press-effect',
  outline: 'w-10 h-10 border border-outline-variant rounded-full flex items-center justify-center text-primary hover:bg-primary hover:text-on-primary transition-all press-effect',
};
---
<div class="flex gap-4">
  {social.map(red => (
    <a
      href={red.href}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`${brand} en ${red.name}`}
      title={red.name}
      class={ESTILOS[variant]}
    >
      <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d={ICONOS[red.name]} />
      </svg>
    </a>
  ))}
</div>
